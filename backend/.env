# MongoDB Atlas - Replace with your Atlas connection string
MONGODB_URI="mongodb://127.0.0.1:27017/revorafit"

# NextAuth
NEXTAUTH_SECRET=revorafit_super_secret_key_change_in_production_2024
NEXTAUTH_URL=http://localhost:3000

# Razorpay - Replace with your actual keys from razorpay.com dashboard
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary - Replace with your Cloudinary credentials
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Admin credentials (initial setup)
ADMIN_EMAIL=admin@revorafit.com
ADMIN_PASSWORD=Admin@123456

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp number for chat support
NEXT_PUBLIC_WHATSAPP_NUMBER=919999999999
